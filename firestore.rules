rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Spots : lecture publique, création par connecté, update/delete seulement par le créateur
    match /spots/{spotId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.ajoutePar == request.auth.uid;
      allow delete: if request.auth != null && resource.data.ajoutePar == request.auth.uid;
    }

    // Profils utilisateur : chacun ne peut lire/modifier que son propre profil
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
