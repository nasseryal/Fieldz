rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Spots : lecture publique, création avec validation, update/delete par le créateur
    match /spots/{spotId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.nom is string
        && request.resource.data.nom.size() >= 3
        && request.resource.data.nom.size() <= 100
        && request.resource.data.sport is string
        && request.resource.data.latitude is number
        && request.resource.data.longitude is number
        && request.resource.data.latitude >= -90
        && request.resource.data.latitude <= 90
        && request.resource.data.longitude >= -180
        && request.resource.data.longitude <= 180
        && request.resource.data.ajoutePar == request.auth.uid;

      // Update par le créateur (modification complète)
      allow update: if request.auth != null
        && resource.data.ajoutePar == request.auth.uid;

      // Update partiel par tout utilisateur connecté (signalement + photos uniquement)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['signalements', 'photos', 'updatedAt']);

      // Suppression par le créateur ou un admin
      allow delete: if request.auth != null
        && (resource.data.ajoutePar == request.auth.uid
            || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));

      // Commentaires communautaires sur les spots
      match /comments/{commentId} {
        allow read: if true;

        allow create: if request.auth != null
          && request.resource.data.texte is string
          && request.resource.data.texte.size() >= 1
          && request.resource.data.texte.size() <= 500
          && request.resource.data.auteurUid == request.auth.uid;

        // Signalement par tout utilisateur connecté
        allow update: if request.auth != null
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['signalements']);

        // Suppression par l'auteur ou un admin
        allow delete: if request.auth != null
          && (resource.data.auteurUid == request.auth.uid
              || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
      }
    }

    // Admins : lecture seule (les documents sont créés manuellement dans Firebase Console)
    match /admins/{adminId} {
      allow read: if request.auth != null;
    }

    // Profils utilisateur : chacun ne peut lire/modifier que son propre profil
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
