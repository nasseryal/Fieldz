rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Photos de spots : lecture publique, écriture/suppression par utilisateur connecté
    // Note : on ne peut pas vérifier le propriétaire du spot depuis Storage rules
    // La suppression est limitée au deleteAccount côté code (auth.ts)
    match /spots/{spotId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }
  }
}
